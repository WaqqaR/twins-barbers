# ─────────────────────────────────────────────────────────────
# Copy this file to .env  (cp .env.example .env)  and fill it in.
# .env is git-ignored. On Vercel, set these in Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# --- Database (libSQL / Turso) ---
# Local development: leave these as-is to use a local SQLite file (server/local.db).
# Production (Vercel): create a free DB at https://turso.tech and paste the values.
#   turso db create barbershop
#   turso db show barbershop --url
#   turso db tokens create barbershop
DATABASE_URL=file:server/local.db
DATABASE_AUTH_TOKEN=

# --- Auth ---
# Used to sign admin login tokens. Generate a long random string for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-change-me

# --- Admin account (seeded automatically on first run if no admin exists) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Local dev server port (Express). The Vite dev server proxies /api here. ---
PORT=4400
